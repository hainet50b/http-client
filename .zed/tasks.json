[
  {
    "label": "$ZED_CUSTOM_method $ZED_CUSTOM_url",
    "command": "$ZED_WORKTREE_ROOT/httpc/target/debug/httpc",
    "args": [
      "--method",
      "$ZED_CUSTOM_method",
      "--url",
      "$ZED_CUSTOM_url",
      "--body",
      "'${ZED_CUSTOM_body:-}'",
    ],
    "tags": ["http-request"],
    "reveal": "no_focus",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
  },
]
